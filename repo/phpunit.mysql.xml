<?xml version="1.0" encoding="UTF-8"?>
<!--
  MySQL-backed integration test configuration.
  Runs against a real MySQL instance to verify production-specific guarantees:
  - Row-level locking (SELECT ... FOR UPDATE)
  - Idempotency key composite uniqueness
  - DateTime column precision
  - Transaction rollback behavior

  Prerequisites:
    MySQL running on 127.0.0.1:3306 with database 'campus_platform_test'
    User: campus / campus_secret (or override via env vars)

  Usage:
    docker compose exec app vendor/bin/phpunit -c phpunit.mysql.xml
    # Or locally:
    DB_HOST=127.0.0.1 DB_DATABASE=campus_platform_test vendor/bin/phpunit -c phpunit.mysql.xml
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:YWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWE="/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_DATABASE" value="campus_platform_test"/>
        <env name="DB_USERNAME" value="campus"/>
        <env name="DB_PASSWORD" value="campus_secret"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
    </php>
</phpunit>
